{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/backoffice/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/portal/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/src/index.js" },
    { "src": "/portal", "dest": "frontend/portal/index.html" },
    { "src": "/portal/(.*)", "dest": "frontend/portal/index.html" },
    { "src": "/(.*)", "dest": "frontend/backoffice/index.html" }
  ]
}
