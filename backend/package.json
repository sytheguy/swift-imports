{
  "name": "swift-imports-backend",
  "version": "1.0.0",
  "description": "Swift Imports Tracking System — Backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev":      "node --watch src/index.js",
    "start":    "node src/index.js",
    "db:push":  "prisma db push",
    "db:seed":  "node prisma/seed.js",
    "db:studio":"prisma studio",
    "db:reset": "prisma migrate reset --force && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs":       "^2.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "jsonwebtoken":   "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}